<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<title>Ваш скрипт</title>

<style>
body{
background:#111;
color:white;
font-family:Arial;
display:flex;
justify-content:center;
align-items:center;
height:100vh;
margin:0;
}

.box{
width:700px;
background:#1c1c1c;
padding:30px;
border-radius:15px;
box-shadow:0 0 20px #000;
}

button{
width:100%;
padding:15px;
font-size:18px;
cursor:pointer;
border:none;
border-radius:10px;
background:#4CAF50;
color:white;
margin-bottom:20px;
}

textarea{
width:100%;
height:350px;
background:#0f0f0f;
color:#00ff88;
border:none;
padding:15px;
font-family:Consolas;
font-size:14px;
resize:none;
}
</style>
</head>

<body>

<div class="box">

<h2>📜 Ваш скрипт</h2>

<button onclick="copyText()">📋 Скопировать скрипт</button>

<textarea id="script" readonly>
СЮДА ВСТАВЛЯЕШЬ СВОЙ LUA КОД
</textarea>

</div>

<script>
function copyText(){
let text=document.getElementById("script");
text.select();
navigator.clipboard.writeText(text.value);
alert("Скрипт скопирован!");
}
</script>

</body>
</html>
